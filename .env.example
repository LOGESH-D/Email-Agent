# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct
LLM_TEMPERATURE=0

# ── Reply ─────────────────────────────────────────────────────────────────────
DEFAULT_REPLY_TONE=professional
REPLY_RISK_THRESHOLD=40

# ── Web Search ────────────────────────────────────────────────────────────────
WEB_SEARCH_MAX_RESULTS=5

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_ADDRESS=your_email@gmail.com

# ── Google Cloud Pub/Sub ──────────────────────────────────────────────────────
PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-notifications
GCP_PROJECT_ID=YOUR_PROJECT_ID

# ── Webhook Server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
WEBHOOK_PUBLIC_URL=https://your-ngrok-or-domain.com
DEBUG=false

# ── Auto-Action Thresholds ────────────────────────────────────────────────────
AUTO_SPAM_THRESHOLD=75
AUTO_DELETE_THRESHOLD=90

# ── Gmail Label Names ─────────────────────────────────────────────────────────
LABEL_NEEDS_REVIEW=Needs Review
LABEL_PHISHING_DETECTED=Phishing Detected

# ── LLM Provider Default Models ───────────────────────────────────────────────
GROQ_DEFAULT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307
OLLAMA_DEFAULT_MODEL=llama3

# ── Simulation (test/simulate endpoint) ──────────────────────────────────────
SIM_MESSAGE_ID=sim-001
SIM_THREAD_ID=sim-thread-001
SIM_FALLBACK_RECIPIENT=you@gmail.com

# ── Ngrok ─────────────────────────────────────────────────────────────────────
NGROCK_AUTH=your_ngrok_auth_token_here
